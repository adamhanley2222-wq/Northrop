APP_NAME=MD Strategic Review AI API
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/md_strategic_review
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
PINECONE_API_KEY=
PINECONE_INDEX_NAME=md-strategic-review
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=chunks
EMBEDDING_DIMENSION=3072
ENABLE_SEMANTIC_RETRIEVAL=true
